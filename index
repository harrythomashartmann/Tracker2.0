<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tracker Database</title>

<style>
body{
    font-family:Arial,sans-serif;
    background:#102334;
    color:white;
    margin:0;
    padding:20px;
}
.container{
    max-width:900px;
    margin:auto;
}
.card{
    background:#1a3148;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;
}
h1,h2{margin-top:0;}
input{
    width:100%;
    padding:10px;
    margin-top:5px;
    margin-bottom:15px;
    border:none;
    border-radius:6px;
    box-sizing:border-box;
}
button{
    padding:10px 15px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    margin-right:5px;
    margin-bottom:10px;
}
.track-btn{background:#28a745;color:white;}
.clear-btn{background:#dc3545;color:white;}
table{
    width:100%;
    border-collapse:collapse;
    background:white;
    color:black;
}
th{background:#e9ecef;}
th,td{
    padding:10px;
    border:1px solid #ddd;
    text-align:left;
}
.duplicate{
    background:#ff0000;
    color:white;
}
video{
    width:100%;
    border-radius:10px;
    background:black;
    margin-bottom:10px;
}
#preview{
    max-width:200px;
    border-radius:10px;
    margin-bottom:15px;
    display:none;
}
</style>
</head>
<body>

<div class="container">

    <div class="card">

        <h1>Tracker</h1>

        <label>Name</label>
        <input type="text" id="name">

        <label>Route Code</label>
        <input type="text" id="routeCode">

        <label>Cart</label>
        <input type="text" id="cart">

        <label>Feedback</label>
        <input type="text" id="feedback">

        <label>Camera</label>

        <video id="video" autoplay playsinline></video>

        <canvas id="canvas" style="display:none;"></canvas>

        <div>
            <button type="button" onclick="startCamera()">Start Camera</button>
            <button type="button" onclick="capturePhoto()">Take Picture</button>
        </div>

        <img id="preview">

        <br>

        <button class="track-btn" onclick="saveRecord()">Track</button>

        <button class="clear-btn" onclick="clearRecords()">Clear Database</button>

    </div>

    <div class="card">

        <h2>Database Records</h2>

        <table>

            <thead>
                <tr>
                    <th>Name</th>
                    <th>Route Code</th>
                    <th>Cart</th>
                    <th>Feedback</th>
                    <th>Photo</th>
                    <th>Date Added</th>
                </tr>
            </thead>

            <tbody id="recordsTable"></tbody>

        </table>

    </div>

</div>

<script>

let records = JSON.parse(localStorage.getItem("records")) || [];
let capturedPhoto = "";
let stream = null;

async function startCamera(){
    try{
        stream = await navigator.mediaDevices.getUserMedia({
            video:{facingMode:"environment"}
        });
        document.getElementById("video").srcObject = stream;
    }catch(error){
        alert("Camera access denied or unavailable.");
        console.error(error);
    }
}

function stopCamera(){
    if(stream){
        stream.getTracks().forEach(track => track.stop());
        stream = null;
    }
}

function capturePhoto(){
    const video = document.getElementById("video");
    const canvas = document.getElementById("canvas");
    const preview = document.getElementById("preview");

    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;

    const ctx = canvas.getContext("2d");
    ctx.drawImage(video,0,0,canvas.width,canvas.height);

    capturedPhoto = canvas.toDataURL("image/jpeg",0.8);

    preview.src = capturedPhoto;
    preview.style.display = "block";

    stopCamera();
}

function saveRecord(){

    const name = document.getElementById("name").value.trim();
    const routeCode = document.getElementById("routeCode").value.trim();
    const cart = document.getElementById("cart").value.trim();
    const feedback = document.getElementById("feedback").value.trim();

    if(!name || !routeCode || !cart || !feedback){
        alert("Please complete all fields.");
        return;
    }

    const now = new Date();

    const dateAdded =
        now.toLocaleDateString("en-GB") + " " +
        now.toLocaleTimeString([],{
            hour:"2-digit",
            minute:"2-digit"
        });

    records.unshift({
        name:name,
        routeCode:routeCode,
        cart:cart,
        feedback:feedback,
        photo:capturedPhoto,
        date:dateAdded
    });

    localStorage.setItem("records", JSON.stringify(records));

    document.getElementById("name").value = "";
    document.getElementById("routeCode").value = "";
    document.getElementById("cart").value = "";
    document.getElementById("feedback").value = "";

    document.getElementById("preview").src = "";
    document.getElementById("preview").style.display = "none";

    capturedPhoto = "";

    loadData();
}

function clearRecords(){

    if(!confirm("Delete all records?")){
        return;
    }

    records = [];
    localStorage.setItem("records", JSON.stringify(records));
    loadData();
}

function loadData(){

    const table = document.getElementById("recordsTable");
    table.innerHTML = "";

    const counts = {};

    records.forEach(record=>{
        const key = record.name.toLowerCase();
        counts[key] = (counts[key] || 0) + 1;
    });

    records.forEach(record=>{

        const row = document.createElement("tr");

        const key = record.name.toLowerCase();

        if(counts[key] > 1){
            row.classList.add("duplicate");
        }

        row.innerHTML = `
            <td>${record.name}</td>
            <td>${record.routeCode || ""}</td>
            <td>${record.cart || ""}</td>
            <td>${record.feedback}</td>
            <td>
                ${
                    record.photo
                    ? `<img src="${record.photo}" width="80" style="border-radius:6px;">`
                    : "No Photo"
                }
            </td>
            <td>${record.date}</td>
        `;

        table.appendChild(row);
    });
}

loadData();

</script>

</body>
</html>
